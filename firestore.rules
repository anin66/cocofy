rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isManager() {
      return isSignedIn() && getUserData().role == 'manager';
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      // Allow any signed-in user to see profiles (managers need this to find workers)
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      // Users can only manage their own profile document
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /jobs/{jobId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isManager();
      // Allow update if the user is the manager who created it, 
      // OR if the user is one of the workers assigned to the job.
      allow update: if isSignedIn() && (
        resource.data.managerId == request.auth.uid || 
        (request.auth.uid in resource.data.get('assignedWorkerIds', []))
      );
      allow delete: if isManager() && resource.data.managerId == request.auth.uid;
    }
    
    // Support for potential future expansion to a dedicated assignments collection
    match /jobAssignments/{assignmentId} {
      allow read: if isSignedIn() && (
        resource.data.workerId == request.auth.uid || 
        resource.data.managerId == request.auth.uid
      );
      allow write: if isSignedIn();
    }
  }
}
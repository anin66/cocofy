
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // --- DEVELOPMENT RULES ---
    // Allow any authenticated user full read/write access for development and debugging.
    // This removes "Missing or insufficient permissions" errors.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
